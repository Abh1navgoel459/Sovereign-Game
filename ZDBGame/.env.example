# ZeroDB Configuration
# Option A: provide direct API base URL
ZERODB_API_URL=
# Option B: provide project id (base URL auto-derived)
ZERODB_PROJECT_ID=your_project_id_here
ZERODB_API_KEY=your_api_key_here

# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Game Configuration
NEXT_PUBLIC_GAME_NAME=ZDBGame Workshop
NEXT_PUBLIC_MAX_PLAYERS=100

# AIKit Nation Response Enrichment (optional)
AIKIT_ENABLED=false
AIKIT_PROVIDER=openai
AIKIT_MODEL=gpt-4o-mini
AIKIT_API_KEY=
# Optional: OpenAI-compatible base URL (for AINative/OpenRouter/etc)
AIKIT_BASE_URL=
